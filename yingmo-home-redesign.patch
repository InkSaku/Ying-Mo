+
+.home-guide-list .guide-card p {
+  display: -webkit-box;
+  overflow: hidden;
+  margin: 0;
+  color: var(--color-text-muted);
+  font-size: 0.78rem;
+  -webkit-box-orient: vertical;
+  -webkit-line-clamp: 1;
+}
+
+.home-guide-list .guide-card small {
+  overflow: hidden;
+  color: var(--color-text-subtle);
+  font-size: 0.72rem;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.home-state {
+  display: grid;
+  min-height: 8rem;
+  place-items: center;
+  border: 1px dashed var(--color-border-strong);
+  border-radius: var(--radius-lg);
+  color: var(--color-text-muted);
+  padding: 1.5rem;
+  text-align: center;
+}
+
+.home-state--error {
+  border-style: solid;
+  border-color: color-mix(in srgb, #b4534a 45%, var(--color-border));
+}
+
+.home-state--loading {
+  align-content: center;
+  gap: 0.75rem;
+}
+
+.home-state--loading span {
+  width: 2rem;
+  height: 2rem;
+  border: 2px solid var(--color-primary-soft);
+  border-top-color: var(--color-primary);
+  border-radius: 50%;
+  animation: home-spin 0.9s linear infinite;
+}
+
+.home-final-entry {
+  background: var(--color-bg);
+}
+
+.home-final-entry__panel {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 2rem;
+  border: 1px solid var(--color-border);
+  border-radius: var(--radius-xl);
+  background:
+    radial-gradient(circle at 86% 15%, var(--color-primary-veil), transparent 24%),
+    var(--color-surface);
+  padding: clamp(1.5rem, 4vw, 3rem);
+  box-shadow: var(--shadow-card);
+}
+
+.home-final-entry__panel > div:first-child {
+  display: grid;
+  max-width: 42rem;
+  gap: 0.45rem;
+}
+
+.home-final-entry__actions {
+  display: flex;
+  flex: 0 0 auto;
+  flex-wrap: wrap;
+  gap: 0.7rem;
+}
+
+@keyframes home-spin {
+  to { transform: rotate(360deg); }
+}
+
+@keyframes home-pulse {
+  to { opacity: 0.45; }
+}
+
+@media (max-width: 1020px) {
+  .home-portal-hero__inner,
+  .home-life-layout,
+  .home-game-layout {
+    grid-template-columns: 1fr;
+  }
+
+  .home-content-window {
+    width: min(42rem, 100%);
+  }
+
+  .home-chapter-rail {
+    position: static;
+  }
+}
+
+@media (max-width: 760px) {
+  .home-module-grid,
+  .home-life-grid,
+  .home-game-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .home-section-heading,
+  .home-final-entry__panel {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .home-life-grid .life-card:first-child {
+    grid-column: auto;
+  }
+
+  .home-life-grid .life-card:first-child .life-card__button {
+    grid-template-columns: 1fr;
+  }
+
+  .home-life-grid .life-card:first-child .life-card__media {
+    min-height: 16rem;
+  }
+
+  .home-module-card__content {
+    grid-template-columns: 1fr 6.5rem;
+  }
+
+  .home-game-preview {
+    grid-template-columns: 3rem minmax(0, 1fr) auto;
+  }
+
+  .home-game-preview__stats {
+    display: none;
+  }
+}
+
+@media (max-width: 520px) {
+  .home-portal-hero {
+    padding-top: 3.25rem;
+  }
+
+  .home-portal-hero__copy h1 {
+    font-size: clamp(2.75rem, 14vw, 4rem);
+  }
+
+  .home-content-window__header {
+    grid-template-columns: 1fr auto;
+  }
+
+  .home-content-window__header p {
+    display: none;
+  }
+
+  .home-live-card {
+    min-height: 18rem;
+  }
+
+  .home-module-card__content {
+    grid-template-columns: 1fr;
+  }
+
+  .home-module-card__media {
+    width: 6.5rem;
+  }
+
+  .home-module-card__footer span:nth-child(3) {
+    display: none;
+  }
+
+  .home-guide-list .guide-card a {
+    grid-template-columns: 5.75rem minmax(0, 1fr);
+  }
+
+  .home-final-entry__actions,
+  .home-final-entry__actions .button {
+    width: 100%;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .home-content-window__skeleton span,
+  .home-state--loading span {
+    animation: none;
+  }
+}
