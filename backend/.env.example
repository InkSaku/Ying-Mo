# Application environment: development, testing, or production.
APP_ENV=development

# MySQL 8.0+ is required in every environment. Replace placeholders; never
# commit real credentials. Keep charset=utf8mb4 for Chinese content.
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/yingmo?charset=utf8mb4
# Optional dedicated MySQL database for non-destructive test runs. If omitted,
# tests use DATABASE_URL.
# TEST_DATABASE_URL=mysql+pymysql://username:password@localhost:3306/yingmo_test?charset=utf8mb4

# Set strong, unique values before production.
SECRET_KEY=replace-with-a-strong-secret
JWT_SECRET_KEY=replace-with-a-different-strong-secret
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# multipart 总请求上限；图片文件本身由 IMAGE_MAX_BYTES 限制为 15 MB。
MAX_CONTENT_LENGTH=16777216
UPLOAD_ROOT=uploads
IMAGE_MAX_BYTES=15728640
IMAGE_MAX_PIXELS=40000000
IMAGE_THUMBNAIL_MAX_SIDE=640
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
